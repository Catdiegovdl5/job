{
  "name": "B2B Lead Triage Pipeline (Silent)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "lead-triage",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "97e6f8fa-848e-4a67-b50a-3c72b22f281e",
      "name": "Webhook (Trigger)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "placeholder-google-sheet-id",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Leads",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Nome": "={{ $json.contato.nome }}",
            "WhatsApp": "={{ $json.contato.whatsapp }}",
            "E-mail": "={{ $json.contato.email }}",
            "Faturamento": "={{ $json.dados_empresa.faturamento }}",
            "Investimento": "={{ $json.dados_empresa.investimento_anuncios }}",
            "Status": "={{ $json.status_qualificacao }}",
            "Data/Hora": "={{ $json.timestamp }}"
          },
          "matchingColumns": []
        },
        "options": {}
      },
      "id": "4b684bc2-8921-4fa3-94c6-2c5e52c8bd6b",
      "name": "Google Sheets (Data Sink)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        500,
        300
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "google-sheets-cred-placeholder",
          "name": "Google Sheets Connection"
        }
      }
    }
  ],
  "connections": {
    "Webhook (Trigger)": {
      "main": [
        [
          {
            "node": "Google Sheets (Data Sink)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "templateCredsSetupCompleted": true
  }
}
